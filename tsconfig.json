{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.ets"
  ],
  "exclude": [
    "node_modules",
    "oh_modules",
    ".hvigor",
    "build",
    "entry/build"
  ]
}
