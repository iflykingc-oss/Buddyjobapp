{
  "module": {
    "name": "entry",
    "type": "entry",
    "launchType": "standard",
    "label": "$string:entry_label",
    "description": "$string:entry_label",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "targetSdkVersion": "5.0.0",
    "compatibleSdkVersion": "5.0.0",
    "querySchemes": [
      "plugs",
      "share",
      "hwid",
      "hmscore",
      "push"
    ],
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:entry_label",
        "icon": "$media:icon",
        "label": "$string:entry_label",
        "startWindowIcon": "$media:icon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "continuable": true,
        "preload": "lazy",
        "supportModes": [
          "portrait",
          "landscape",
          "portrait-inactive",
          "landscape-inactive"
        ],
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET",
        "reason": "$string:permission_internet_reason"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO",
        "reason": "$string:permission_network_info_reason"
      },
      {
        "name": "ohos.permission.PUSH_TOKEN",
        "reason": "$string:permission_push_token_reason"
      },
      {
        "name": "ohos.permission.RECEIVE_PUSH_MESSAGE",
        "reason": "$string:permission_push_message_reason"
      },
      {
        "name": "ohos.permission.ACCESS_BIOMETRIC",
        "reason": "$string:permission_biometric_reason"
      },
      {
        "name": "ohos.permission.READ_FILE",
        "reason": "$string:permission_read_file_reason"
      },
      {
        "name": "ohos.permission.WRITE_FILE",
        "reason": "$string:permission_write_file_reason"
      },
      {
        "name": "ohos.permission.DISTRIBUTED_DATASYNC",
        "reason": "$string:permission_distributed_reason"
      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:permission_microphone_reason"
      }
    ],
    "metadata": [
      {
        "name": "hms_account_kit",
        "value": "true"
      },
      {
        "name": "hms_push_kit",
        "value": "true"
      },
      {
        "name": "hms_iap_kit",
        "value": "true"
      },
      {
        "name": "hms_analytics_kit",
        "value": "true"
      },
      {
        "name": "hms_crash_kit",
        "value": "true"
      },
      {
        "name": "hms_app_id",
        "value": "$string:hms_app_id"
      },
      {
        "name": "hms_cp_id",
        "value": "$string:hms_cp_id"
      },
      {
        "name": "hms_product_id",
        "value": "$string:hms_product_id"
      },
      {
        "name": "hms_client_id",
        "value": "$string:hms_client_id"
      },
      {
        "name": "hms_client_secret",
        "value": "$string:hms_client_secret"
      },
      {
        "name": "hms_api_key",
        "value": "$string:hms_api_key"
      },
      {
        "name": "hms_cert_fingerprint",
        "value": "$string:hms_cert_fingerprint"
      }
    ],
    "extensionAbilities": [
      {
        "name": "XiaoyiAgentExtension",
        "srcEntry": "./ets/services/XiaoyiAgentExtension.ets",
        "type": "intelligentAgent",
        "description": "小艺智能体扩展能力",
        "exported": true
      },
      {
        "name": "SelectionExtensionAbility",
        "srcEntry": "./ets/services/SelectionExtensionAbility.ets",
        "type": "selection",
        "description": "小艺圈选分析扩展能力",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.text"
            ],
            "actions": [
              "ohos.want.action.sendText"
            ],
            "uris": [
              {
                "type": "text/plain"
              }
            ]
          }
        ]
      },
      {
        "name": "BackupExtension",
        "srcEntry": "./ets/extensionability/BackupExtension.ets",
        "type": "backupExtension"
      }
    ],
    "intents": [
      {
        "intent": {
          "name": "buddyjob.analyze_resume",
          "action": "analyze_resume",
          "entities": [
            {
              "name": "resumeId",
              "type": "string"
            },
            {
              "name": "targetPosition",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.interview_practice",
          "action": "interview_practice",
          "entities": [
            {
              "name": "jobType",
              "type": "string"
            },
            {
              "name": "difficulty",
              "type": "string"
            },
            {
              "name": "company",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.assess_ability",
          "action": "assess_ability",
          "entities": [
            {
              "name": "assessmentType",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.circle_selection",
          "action": "circle_selection",
          "entities": [
            {
              "name": "selectedText",
              "type": "string"
            },
            {
              "name": "context",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.voice_memo",
          "action": "voice_memo",
          "entities": [
            {
              "name": "audioUri",
              "type": "string"
            },
            {
              "name": "interviewId",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.analyze_offer",
          "action": "analyze_offer",
          "entities": [
            {
              "name": "offerId",
              "type": "string"
            },
            {
              "name": "company",
              "type": "string"
            },
            {
              "name": "position",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.career_advice",
          "action": "career_advice",
          "entities": [
            {
              "name": "industry",
              "type": "string"
            },
            {
              "name": "experience",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.job_suggestion",
          "action": "job_suggestion",
          "entities": [
            {
              "name": "location",
              "type": "string"
            },
            {
              "name": "industry",
              "type": "string"
            },
            {
              "name": "query",
              "type": "string"
            }
          ]
        }
      },
      {
        "intent": {
          "name": "buddyjob.interview_reminder",
          "action": "interview_reminder",
          "entities": [
            {
              "name": "interviewId",
              "type": "string"
            },
            {
              "name": "company",
              "type": "string"
            },
            {
              "name": "time",
              "type": "string"
            }
          ]
        }
      }
    ]
  }
}
