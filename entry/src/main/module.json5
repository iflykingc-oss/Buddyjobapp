{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:entry_label",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "querySchemes": [
      "plugs",
      "share",
      "hwid",
      "hmscore",
      "push"
    ],
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:entry_label",
        "icon": "$media:icon",
        "label": "$string:entry_label",
        "startWindowIcon": "$media:icon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "continuable": true,
        "orientation": "all",
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ]
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET",
        "reason": "$string:permission_internet_reason"
      },
      {
        "name": "ohos.permission.GET_NETWORK_INFO",
        "reason": "$string:permission_network_info_reason"
      },
      {
        "name": "ohos.permission.RECEIVE_PUSH_MESSAGE",
        "reason": "$string:permission_push_message_reason"
      },
      {
        "name": "ohos.permission.ACCESS_BIOMETRIC",
        "reason": "$string:permission_biometric_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.READ_FILE",
        "reason": "$string:permission_read_file_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.WRITE_FILE",
        "reason": "$string:permission_write_file_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.DISTRIBUTED_DATASYNC",
        "reason": "$string:permission_distributed_reason"
      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:permission_microphone_reason",
        "usedScene": {
          "abilities": ["EntryAbility"],
          "when": "always"
        }
      }
    ],
    "metadata": [
      {
        "name": "hms_account_kit",
        "value": "true"
      },
      {
        "name": "hms_push_kit",
        "value": "true"
      },
      {
        "name": "hms_iap_kit",
        "value": "true"
      },
      {
        "name": "hms_analytics_kit",
        "value": "true"
      },
      {
        "name": "hms_crash_kit",
        "value": "true"
      },
      {
        "name": "hms_app_id",
        "value": "$string:hms_app_id"
      },
      {
        "name": "hms_cp_id",
        "value": "$string:hms_cp_id"
      },
      {
        "name": "hms_product_id",
        "value": "$string:hms_product_id"
      },
      {
        "name": "hms_client_id",
        "value": "$string:hms_client_id"
      },
      {
        "name": "hms_client_secret",
        "value": "$string:hms_client_secret"
      },
      {
        "name": "hms_api_key",
        "value": "$string:hms_api_key"
      },
      {
        "name": "hms_cert_fingerprint",
        "value": "$string:hms_cert_fingerprint"
      }
    ],
    "extensionAbilities": [
      {
        "name": "XiaoyiAgentExtension",
        "srcEntry": "./ets/services/XiaoyiAgentExtension.ets",
        "type": "agent",
        "description": "小艺智能体扩展能力",
        "exported": true
      },
      {
        "name": "SelectionExtensionAbility",
        "srcEntry": "./ets/services/SelectionExtensionAbility.ets",
        "type": "selection",
        "description": "小艺圈选分析扩展能力",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.text"
            ],
            "actions": [
              "ohos.want.action.sendText"
            ],
            "uris": [
              {
                "type": "text/plain"
              }
            ]
          }
        ]
      }
    ]
  }
}