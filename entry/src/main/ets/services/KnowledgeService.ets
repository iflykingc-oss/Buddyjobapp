import { ApiService } from './ApiService';
import { API_ENDPOINTS } from '../constants/config';
import { DataLoadService } from './DataLoadService';
import { DataConverter } from './DataConverter';

/**
 * 知识库文章接口
 */
export interface KnowledgeArticle {
  id: string;
  title: string;
  category: string;
  summary: string;
  readCount: number;
  updateTime: string;
  coverImage?: string;
}

/**
 * 文章详情接口
 */
export interface ArticleDetail {
  id: string;
  title: string;
  category: string;
  publishTime: string;
  readCount: number;
  content: string;
  author: string;
  coverImage?: string;
  tags?: string[];
  url?: string;
}

/**
 * 文章列表响应
 */
export interface ArticleListResponse {
  list: KnowledgeArticle[];
  total: number;
  page: number;
  limit: number;
  hasMore: boolean;
}

/**
 * KnowledgeService - 知识库服务
 *
 * 管理知识库文章的获取、搜索和收藏
 *
 * @example
 * const service = KnowledgeService.getInstance();
 * const articles = await service.getArticles('面试攻略', 1, 20);
 * const detail = await service.getArticleById('1');
 * await service.addToFavorites('1');
 *
 * @since 1.0.0
 */
export class KnowledgeService {
  private apiService: ApiService;
  private static instance: KnowledgeService;
  private dataLoadService: DataLoadService = DataLoadService.getInstance();
  private dataConverter: DataConverter = DataConverter.getInstance();
  private loadedArticles: KnowledgeArticle[] = [];

  private constructor() {
    this.apiService = ApiService.getInstance();
  }

  static getInstance(): KnowledgeService {
    if (!KnowledgeService.instance) {
      KnowledgeService.instance = new KnowledgeService();
    }
    return KnowledgeService.instance;
  }

  /**
   * 初始化数据加载服务，从 rawfile JSON 文件加载知识库文章数据
   * 加载失败时静默回退到内置默认数据，不影响应用正常运行
   * @param context 应用上下文
   */
  async initialize(context: Context): Promise<void> {
    try {
      await this.dataLoadService.initialize(context);
      console.info('[KnowledgeService] DataLoadService 初始化成功');

      // 优先加载 v2 知识库数据（2000篇，43子分类）
      let v2Loaded = false;
      try {
        const v2Data = await this.dataLoadService.loadLocalJson<Record<string, Object>>('data/knowledge_articles_v2.json');
        if (v2Data !== null && v2Data.articles && v2Data.articles.length > 0) {
          this.loadedArticles = this.dataConverter.convertKnowledgeArticlesV2(v2Data);
          if (this.loadedArticles.length > 0) {
            v2Loaded = true;
            console.info(`[KnowledgeService] v2知识库文章加载成功，共 ${this.loadedArticles.length} 篇文章`);
          }
        }
      } catch (error) {
        console.error('[KnowledgeService] v2知识库文章加载失败，回退到v1:', error);
      }

      // v1 回退：加载旧版知识库文章数据
      if (!v2Loaded) {
        try {
          const rawData = await this.dataLoadService.loadLocalJson<Record<string, Object>>('data/knowledge_articles.json');
          if (rawData !== null) {
            this.loadedArticles = this.dataConverter.convertKnowledgeArticles(rawData);
            console.info(`[KnowledgeService] 知识库文章加载成功（v1回退），共 ${this.loadedArticles.length} 篇文章`);
          }
        } catch (error) {
          console.error('[KnowledgeService] 知识库文章加载失败，将使用默认数据:', error);
        }
      }
    } catch (error) {
      console.error('[KnowledgeService] 初始化失败，将使用内置默认数据:', error);
    }
  }

  /**
   * 获取文章列表
   * @param category 分类筛选（可选）
   * @param page 页码（从1开始）
   * @param limit 每页数量
   * @returns 文章列表响应
   */
  async getArticles(
    category?: string,
    page: number = 1,
    limit: number = 20
  ): Promise<ApiResponse<ArticleListResponse>> {
    try {
      const params: Record<string, string | number> = { page, limit };
      if (category && category !== '全部' && category !== '我的收藏') {
        params.category = category;
      }

      const response = await this.apiService.get<ArticleListResponse>(
        API_ENDPOINTS.KNOWLEDGE_LIST,
        params
      );

      return response;
    } catch (error) {
      console.error('[KnowledgeService] Get articles failed:', error);

      // API 失败时，优先使用 rawfile 加载的文章
      if (this.loadedArticles.length > 0) {
        let filtered = this.loadedArticles;
        if (category && category !== '全部' && category !== '我的收藏') {
          filtered = filtered.filter(a => a.category === category);
        }
        const total = filtered.length;
        const start = (page - 1) * limit;
        const items = filtered.slice(start, start + limit);
        return {
          success: true,
          data: {
            list: items,
            total: total,
            page: page,
            limit: limit,
            hasMore: start + limit < total
          },
          message: '从本地数据加载'
        };
      }

      return {
        success: false,
        data: null as ArticleListResponse,
        error: '获取文章列表失败'
      };
    }
  }

  /**
   * 获取文章详情
   * @param id 文章ID
   * @returns 文章详情
   */
  async getArticleById(id: string): Promise<ApiResponse<ArticleDetail>> {
    try {
      const response = await this.apiService.get<ArticleDetail>(
        `${API_ENDPOINTS.KNOWLEDGE_DETAIL}/${id}`
      );

      return response;
    } catch (error) {
      console.error('[KnowledgeService] Get article detail failed:', error);
      return {
        success: false,
        data: null as ArticleDetail,
        error: '获取文章详情失败'
      };
    }
  }

  /**
   * 搜索文章
   * @param keyword 搜索关键词
   * @param page 页码
   * @param limit 每页数量
   * @returns 搜索结果
   */
  async searchArticles(
    keyword: string,
    page: number = 1,
    limit: number = 20
  ): Promise<ApiResponse<ArticleListResponse>> {
    try {
      const response = await this.apiService.get<ArticleListResponse>(
        `${API_ENDPOINTS.KNOWLEDGE_LIST}/search`,
        { keyword, page, limit }
      );

      return response;
    } catch (error) {
      console.error('[KnowledgeService] Search articles failed:', error);
      return {
        success: false,
        data: null as ArticleListResponse,
        error: '搜索文章失败'
      };
    }
  }

